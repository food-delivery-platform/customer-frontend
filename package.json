{
  "name": "customer-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:api\"",
    "dev:next": "next dev",
    "dev:api": "json-server --watch json-server/db.json --routes json-server/routes.json --port 8080",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "axios": "^1.18.1",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "json-server": "^0.17.4",
    "typescript": "^5"
  }
}
